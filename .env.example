# ==============================================================================
# Database Configuration (PostgreSQL)
# ==============================================================================
DB_HOST=ticket-postgres
DB_PORT=5432
DB_NAME=ticket_db
DB_USERNAME=postgres
DB_PASSWORD=your_secure_db_password_here

# ==============================================================================
# Redis Configuration
# ==============================================================================
REDIS_HOST=ticket-redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here_if_any

# ==============================================================================
# Backend Security & JWT Settings
# ==============================================================================
JWT_SECRET=your_jwt_signing_key_secret_here_must_be_strong_and_long
JWT_EXPIRATION_MS=86400000

# ==============================================================================
# OAuth2 Authentication (Google)
# ==============================================================================
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth2/redirect

# ==============================================================================
# Cloudinary Image Storage Settings
# ==============================================================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ==============================================================================
# Frontend Applications Environment Config
# ==============================================================================
VITE_API_URL=http://localhost:8080
VITE_USE_MOCK=false
